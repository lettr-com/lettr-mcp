{
  "name": "lettr-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Lettr email API — send transactional emails, manage templates, domains, and webhooks from any AI assistant",
  "keywords": [
    "lettr",
    "email",
    "email-api",
    "transactional-email",
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "templates",
    "email-templates"
  ],
  "homepage": "https://lettr.com",
  "license": "MIT",
  "type": "module",
  "bin": {
    "lettr-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', '755')\"",
    "prepare": "npm run build",
    "inspector": "npx @modelcontextprotocol/inspector@latest",
    "lint": "biome check .",
    "lint:fix": "biome check . --write"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "minimist": "1.2.8",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.2",
    "@types/minimist": "1.2.5",
    "@types/node": "25.0.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.30.0"
}
